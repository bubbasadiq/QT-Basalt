# Qutlas Environment Configuration
# Copy this file to .env and fill in values.
# Never commit .env to the repository.

# ── Application ──────────────────────────────
QUTLAS_ENV=development          # development | staging | production
QUTLAS_LOG_LEVEL=INFO           # DEBUG | INFO | WARNING | ERROR
QUTLAS_VERSION=0.1.0

# ── API ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-this-in-production

# ── Data Pipeline ────────────────────────────
PIPELINE_BUFFER_SIZE=10000      # Ring buffer size (number of timesteps)
PIPELINE_SAMPLE_RATE_HZ=100     # Sensor sampling rate
PIPELINE_EXPORT_PATH=./data-pipeline/export/runs

# ── Simulator (Phase 1) ──────────────────────
SIMULATOR_ENABLED=true
SIMULATOR_NOISE_LEVEL=0.02      # Gaussian noise on simulated sensors (0–1)
SIMULATOR_TIMESTEP_MS=10        # Simulation timestep in milliseconds

# ── Models ───────────────────────────────────
MODEL_CHECKPOINT_DIR=./models/training/checkpoints
MLFLOW_TRACKING_URI=./models/training/experiments/mlruns

# ── Hardware (Phase 2+) ──────────────────────
# Leave empty in Phase 1 — simulator replaces hardware
FURNACE_SERIAL_PORT=
DRAW_CONTROLLER_PORT=
SENSOR_BUS_ADDRESS=

# ── Cloud (Phase 4) ──────────────────────────
CLOUD_API_ENDPOINT=
CLOUD_API_KEY=
